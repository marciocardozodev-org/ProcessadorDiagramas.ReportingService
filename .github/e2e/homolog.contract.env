# ============================================================
# Contrato versionado de execução E2E — Homolog
# Versão: 1.0.0
# ============================================================
# Este arquivo é compartilhado entre terminal local e pipeline CI.
# Segredos (AWS keys, senhas, URLs com credencial) ficam FORA deste arquivo.
# Para execução local, crie .github/e2e/homolog.local.secrets.env (não versionado).
# ============================================================

# --- AWS ---
AWS_REGION=us-east-1

# --- S3 ---
S3_BUCKET_NAME=processador-diagramas-processingservice-hml-inputs-767398027345
S3_KEY_PREFIX=uploads/reporting

# --- Filas SQS ---
# Fila de entrada de resultados de análise
ANALYSIS_COMPLETED_QUEUE_NAME=upload-orchestrator-analysis-completed

# --- Timeout e polling ---
TIMEOUT_SECONDS=240
POLL_INTERVAL_SECONDS=3

# --- API ---
# Sobrescrever com secret no pipeline; em local, pode ser definido em homolog.local.secrets.env
# API_BASE_URL=https://homolog.processador-diagramas.internal

# --- Artefatos ---
ARTIFACT_DIR=artifacts/serverless-e2e

# --- Modo de execução ---
# REQUIRE_FULL_SERVERLESS=false
